---
interface Skill {
  category: string;
  items: string[];
}

const skills: Skill[] = [
  {
    category: 'React',
    items: ['Componentes', 'Hooks', 'Context API', 'Redux', 'React Router', 'Props & State']
  },
  {
    category: 'Frontend',
    items: ['HTML5', 'CSS3', 'JavaScript ES6+', 'Tailwind CSS', 'Responsive Design', 'TypeScript']
  },
  {
    category: 'Ferramentas',
    items: ['Git & GitHub', 'VS Code', 'npm', 'Vite', 'DevTools', 'Figma']
  },
  {
    category: 'Aprendizado',
    items: ['APIs REST', 'Fetch/Axios', 'Web Design', 'Performance', 'Clean Code']
  }
];
---

<section id="habilidades" class="py-20 px-4 sm:px-6 lg:px-8 bg-slate-800/50">
  <div class="max-w-6xl mx-auto">
    <h2 class="text-4xl sm:text-5xl font-bold mb-4 bg-clip-text text-transparent bg-gradient-to-r from-indigo-400 to-purple-400">
      Habilidades
    </h2>
    <p class="text-slate-400 text-lg mb-12 max-w-2xl">
      Tecnologias e competências que domino
    </p>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
      {skills.map((skillGroup) => (
        <div class="bg-gradient-to-br from-slate-700 to-slate-800 rounded-lg p-6 border border-slate-600 hover:border-indigo-500 transition">
          <h3 class="text-xl font-bold mb-4 text-indigo-400">{skillGroup.category}</h3>
          <ul class="space-y-2">
            {skillGroup.items.map((item) => (
              <li class="flex items-center gap-2 text-slate-300 hover:text-indigo-300 transition">
                <span class="w-2 h-2 bg-indigo-500 rounded-full"></span>
                {item}
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </div>
</section>
