---
interface Project {
  title: string;
  description: string;
  tags: string[];
  link?: string;
  github?: string;
  image?: string;
}

const projects: Project[] = [
  {
    title: 'Projeto 1',
    description: 'Descrição do seu primeiro projeto incrível',
    tags: ['React', 'Node.js', 'MongoDB'],
    link: '#',
    github: '#'
  },
  {
    title: 'Projeto 2',
    description: 'Descrição do seu segundo projeto interessante',
    tags: ['Next.js', 'Tailwind', 'PostgreSQL'],
    link: '#',
    github: '#'
  },
  {
    title: 'Projeto 3',
    description: 'Descrição do seu terceiro projeto fantástico',
    tags: ['Vue.js', 'Firebase', 'TypeScript'],
    link: '#',
    github: '#'
  }
];
---

<section id="projetos" class="py-20 px-4 sm:px-6 lg:px-8">
  <div class="max-w-6xl mx-auto">
    <h2 class="text-4xl sm:text-5xl font-bold mb-4 bg-clip-text text-transparent bg-gradient-to-r from-indigo-400 to-purple-400">
      Projetos
    </h2>
    <p class="text-slate-400 text-lg mb-12 max-w-2xl">
      Alguns dos projetos que desenvolvi e que demonstram minha experiência
    </p>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {projects.map((project) => (
        <div class="group relative bg-gradient-to-br from-slate-800 to-slate-900 rounded-lg border border-slate-700 hover:border-indigo-500 transition overflow-hidden hover:shadow-lg hover:shadow-indigo-500/20">
          <!-- Overlay gradient on hover -->
          <div class="absolute inset-0 bg-gradient-to-t from-indigo-500/10 to-transparent opacity-0 group-hover:opacity-100 transition duration-300"></div>
          
          <div class="relative z-10 p-6">
            <h3 class="text-xl font-bold mb-2 text-white">{project.title}</h3>
            <p class="text-slate-400 mb-4">{project.description}</p>
            
            <div class="flex flex-wrap gap-2 mb-6">
              {project.tags.map((tag) => (
                <span class="px-3 py-1 bg-indigo-500/20 border border-indigo-500/50 rounded-full text-sm text-indigo-300">
                  {tag}
                </span>
              ))}
            </div>

            <div class="flex gap-3">
              {project.link && (
                <a href={project.link} class="px-4 py-2 bg-indigo-600 hover:bg-indigo-700 rounded transition">
                  Ver Live
                </a>
              )}
              {project.github && (
                <a href={project.github} class="px-4 py-2 border border-slate-600 hover:border-indigo-500 rounded transition">
                  GitHub
                </a>
              )}
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
