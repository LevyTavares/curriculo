{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "curriculo",
  "type": "javascript",
  "compatibility_date": "2026-04-27",
  "build": {
    "command": "npm run build",
    "cwd": "./",
    "watch_paths": ["src/**/*.{ts,tsx,astro}"]
  },
  "observability": {
    "enabled": true
  }
}
